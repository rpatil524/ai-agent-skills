@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix onto: <../ontology.ttl#> .

<> a schema:CreativeWork ;
    schema:name "YouID Delegation — Local File Modification Pattern"@en ;
    schema:description "Detailed workflow for applying WebID On-Behalf-Of delegation triples to local profile files. The delegation triple is written to the delegator's local profile documents (TTL, JSON-LD, RDFa HTML) — never deployed server-side via PATCH."@en ;
    schema:dateCreated "2026-06-16"^^xsd:date ;
    schema:dateModified "2026-07-01"^^xsd:date ;
    schema:about :delegationGuide .

:delegationGuide a schema:HowTo ;
    schema:name "How to set up WebID On-Behalf-Of Delegation"@en ;
    schema:description "Applies delegation triples to local YouID profile files using edit_file, then the user uploads manually. Includes curl On-Behalf-Of header format requirements."@en ;
    schema:step :stepElicitDelegator, :stepElicitDelegate, :stepElicitRole,
        :stepElicitDelegatorDir, :stepElicitDelegateDir,
        :stepEditProfileTtl, :stepEditProfileJsonld, :stepEditProfileRdfa, :stepEditIndexHtml,
        :stepEditDelegateFiles, :stepGenerateDnrRule, :stepPresentForUpload, :stepVerify,
        :stepOboHeaderFormat14 .

:stepElicitDelegator a schema:HowToStep ;
    schema:position 1 ;
    schema:name "Elicit Delegator WebID/NetID"@en ;
    schema:text "Ask: 'What is the WebID or NetID of the entity granting delegation authority?' The answer is a URL pointing to the delegator's WebID profile (e.g., https://kingsley.idehen.net/DAV/.../index.html#netid)."@en .

:stepElicitDelegate a schema:HowToStep ;
    schema:position 2 ;
    schema:name "Elicit Delegate WebID/NetID"@en ;
    schema:text "Ask: 'What is the WebID or NetID of the entity that will act on behalf of the delegator?' May be a person, organization, or software agent."@en .

:stepElicitRole a schema:HowToStep ;
    schema:position 3 ;
    schema:name "Elicit Delegation Role"@en ;
    schema:text "Ask: 'What delegation role should be granted? Choose one: identify, inform, consult, authority.'"@en .

:stepElicitDelegatorDir a schema:HowToStep ;
    schema:position 4 ;
    schema:name "Elicit Delegator's Local Directory"@en ;
    schema:text "Ask: 'What is the local directory path for the delegator's YouID profile files?' This is the user's local credentials folder containing profile.ttl, profile.jsonld, profile_rdfa.html, index.html, and other identity documents."@en .

:stepElicitDelegateDir a schema:HowToStep ;
    schema:position 5 ;
    schema:name "Elicit Delegate's Local Directory"@en ;
    schema:text "Ask: 'Does the delegate also have a local directory with profile files? If so, what is the path?' If provided, oplcert:onBehalfOf will be added to the delegate's local files too."@en .

:stepEditProfileTtl a schema:HowToStep ;
    schema:position 6 ;
    schema:name "Edit profile.ttl — add oplcert:hasIdentityDelegate"@en ;
    schema:text "Read profile.ttl from the delegator's directory. Find the #netid entity block (the one with schema:name, schema:email, pim:storage). Append:\n  oplcert:hasIdentityDelegate <delegate-webid> .\nThe delegate-webid is the full WebID/NetID URL of the delegate."@en .

:stepEditProfileJsonld a schema:HowToStep ;
    schema:position 7 ;
    schema:name "Edit profile.jsonld — add delegation in @graph"@en ;
    schema:text "Read profile.jsonld from the delegator's directory. Find the #netid graph entry (the schema:Person block with schema:name, schema:email). Add:\n  \"oplcert:hasIdentityDelegate\": { \"@id\": \"<delegate-webid>\" }"@en .

:stepEditProfileRdfa a schema:HowToStep ;
    schema:position 8 ;
    schema:name "Edit profile_rdfa.html — add RDFa and embedded JSON-LD"@en ;
    schema:text "Two changes needed:\n1. Find the <div typeof=\"rdfs:Resource\" about=\"...#netid\"> block. Add:\n   <div rel=\"oplcert:hasIdentityDelegate\" resource=\"<delegate-webid>\"></div>\n2. Find the embedded JSON-LD @graph entry for #netid (schema:Person block). Add:\n   \"oplcert:hasIdentityDelegate\": { \"@id\": \"<delegate-webid>\" }"@en .

:stepEditIndexHtml a schema:HowToStep ;
    schema:position 9 ;
    schema:name "Edit index.html — add embedded JSON-LD and hidden RDFa"@en ;
    schema:text "Two changes needed:\n1. In the <!-- Embedded JSON-LD --> script block, add a graph entry for #netid with oplcert:hasIdentityDelegate.\n2. In the <!-- Hidden RDFa annotations --> section before </body>, add:\n   <div typeof=\"schema:Person\" about=\"...#netid\">\n     <div rel=\"oplcert:hasIdentityDelegate\" resource=\"<delegate-webid>\"></div>\n   </div>"@en .

:stepEditDelegateFiles a schema:HowToStep ;
    schema:position 10 ;
    schema:name "Apply oplcert:onBehalfOf to delegate's files (if directory provided)"@en ;
    schema:text "If the user provided a delegate directory, apply the same edits but with oplcert:onBehalfOf <delegator-webid> instead of oplcert:hasIdentityDelegate."@en .

:stepGenerateDnrRule a schema:HowToStep ;
    schema:position 11 ;
    schema:name "Generate declarativeNetRequest rule JSON"@en ;
    schema:text "Generate a delegation-rule.json file for the delegate's Chrome extension. The rule injects the On-Behalf-Of header into all XHR requests. Save alongside the delegate's profile files."@en .

:stepPresentForUpload a schema:HowToStep ;
    schema:position 12 ;
    schema:name "Present modified files to user"@en ;
    schema:text "List every file that was modified and the exact triple added. Tell the user: 'The delegation triple has been added to the following files. Upload them to the server to deploy the delegation.'"@en .

:stepVerify a schema:HowToStep ;
    schema:position 13 ;
    schema:name "Verify after upload"@en ;
    schema:text "After the user confirms upload, suggest verifying by describing the delegator's WebID and checking for oplcert:hasIdentityDelegate triples."@en .

:stepOboHeaderFormat14 a schema:HowToStep ;
    schema:position 14 ;
    schema:name "Use bare WebID URI in On-Behalf-Of header — no angle brackets"@en ;
    schema:text """CRITICAL: The On-Behalf-Of HTTP header value must be a bare WebID URI without angle brackets. Correct:
  curl ... -H "On-Behalf-Of: https://example.com/dataspace/person/user@example.com"
Incorrect (causes 402/401):
  curl ... -H "On-Behalf-Of: <https://example.com/dataspace/person/user@example.com>"
Angle brackets cause delegation resolution failure even when the reciprocal delegation triples are correctly installed on both sides. The SPARQL endpoint interprets the angle brackets as literal characters, breaking the WebID lookup chain."@en .
