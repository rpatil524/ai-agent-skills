@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<> a schema:CreativeWork ;
    schema:name "Virtuoso SPARQL URL Format Parameters"@en ;
    schema:description "Default &format= parameter values to use when constructing SPARQL URLs targeting Virtuoso endpoints, by query type."@en ;
    schema:dateCreated "2026-06-05T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-06-05T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :virtuosoSparqlFormats .

:virtuosoSparqlFormats a schema:HowTo ;
    schema:name "Virtuoso SPARQL Format Parameter Rules"@en ;
    schema:description "Rules governing the &format= parameter value for each SPARQL query type when targeting a Virtuoso endpoint (e.g. wikidata.demo.openlinksw.com/sparql, linkeddata.uriburner.com/sparql)."@en ;
    schema:step :step-selectFormat, :step-constructFormat, :step-describeFormat, :step-encoding .

:step-selectFormat a schema:HowToStep ;
    schema:position 1 ;
    schema:name "SELECT queries: use text/x-html+tr"@en ;
    schema:text "For SELECT queries, append &format=text%2Fx-html%2Btr to the SPARQL URL. This renders an HTML5 table with faceted browsing links."@en ;
    schema:valueRequired "text/x-html+tr" ;
    schema:url "?format=text%2Fx-html%2Btr" .

:step-constructFormat a schema:HowToStep ;
    schema:position 2 ;
    schema:name "CONSTRUCT queries: use text/x-html-nice-turtle"@en ;
    schema:text "For CONSTRUCT queries, append &format=text%2Fx-html-nice-turtle to the SPARQL URL. This renders an HTML5 Turtle document."@en ;
    schema:valueRequired "text/x-html-nice-turtle" ;
    schema:url "?format=text%2Fx-html-nice-turtle" .

:step-describeFormat a schema:HowToStep ;
    schema:position 3 ;
    schema:name "DESCRIBE queries: use text/x-html-nice-turtle"@en ;
    schema:text "For DESCRIBE queries, append &format=text%2Fx-html-nice-turtle to the SPARQL URL. Same rendering as CONSTRUCT."@en ;
    schema:valueRequired "text/x-html-nice-turtle" ;
    schema:url "?format=text%2Fx-html-nice-turtle" .

:step-encoding a schema:HowToStep ;
    schema:position 4 ;
    schema:name "Always percent-encode the format value"@en ;
    schema:text "The format parameter value must be percent-encoded in the URL: text/x-html+tr → text%2Fx-html%2Btr ; text/x-html-nice-turtle → text%2Fx-html-nice-turtle. Never pass the raw unencoded string."@en .

:formatTable a schema:Table ;
    schema:name "SPARQL Query Type → Format Parameter Mapping"@en ;
    schema:description "Quick-reference table mapping SPARQL query types to their correct Virtuoso format parameter values."@en ;
    schema:about
        [ a schema:PropertyValue ; schema:name "SELECT"@en ;     schema:value "text/x-html+tr" ;          schema:description "HTML5 table with faceted browsing links"@en ] ,
        [ a schema:PropertyValue ; schema:name "CONSTRUCT"@en ;  schema:value "text/x-html-nice-turtle" ; schema:description "HTML5 Turtle document"@en ] ,
        [ a schema:PropertyValue ; schema:name "DESCRIBE"@en ;   schema:value "text/x-html-nice-turtle" ; schema:description "HTML5 Turtle document"@en ] .
