    opal:messageOf :session ;
    opal:usesTools false ;
    opal:timestamp "2026-06-15T13:20:00Z"^^xsd:dateTime .

:prompt3 a opal:PromptText ;
    rdf:value "Yes, but why are you using memory.md instead of what's outlined in preferences.ttl?"@en .

